// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model
model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())
  interviews   Interview[]

  @@map("users")
}

// Interview Model
model Interview {
  id                String             @id @default(uuid())
  userId            String
  role              String
  interviewType     String // Technical, Non-Technical, Mixed
  techStack         String[]
  experienceLevel   String // Entry, Mid, Senior
  numberOfQuestions Int
  status            String             @default("pending") // pending, in_progress, completed
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  // Relations
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions         Question[]
  feedback          Feedback?
  transcriptChunks  TranscriptChunk[]

  @@map("interviews")
  @@index([userId])
}

// Question Model
model Question {
  id           String   @id @default(uuid())
  interviewId  String
  questionText String   @db.Text
  orderIndex   Int
  createdAt    DateTime @default(now())
  
  // Relations
  interview    Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  answer       Answer?

  @@map("questions")
  @@index([interviewId])
}

// Answer Model
model Answer {
  id          String   @id @default(uuid())
  interviewId String
  questionId  String   @unique
  transcript  String   @db.Text
  createdAt   DateTime @default(now())
  
  // Relations
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answers")
  @@index([interviewId])
}

// Feedback Model
model Feedback {
  id           String   @id @default(uuid())
  interviewId  String   @unique
  strengths    Json // Array of strings
  weaknesses   Json // Array of strings
  improvements Json // Array of strings
  summary      String   @db.Text
  score        Int // 0-100
  createdAt    DateTime @default(now())
  
  // Relations
  interview    Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

// TranscriptChunk Model (stores full conversation)
model TranscriptChunk {
  id          String   @id @default(uuid())
  interviewId String
  speaker     String // "AI" or "USER"
  text        String   @db.Text
  timestamp   DateTime @default(now())
  
  // Relations
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("transcript_chunks")
  @@index([interviewId])
}
